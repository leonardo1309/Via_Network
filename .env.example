# Foundry deployment config — copy to .env (already gitignored) and fill in real values.

# Deployer key for `forge script`. Use a throwaway testnet key for Celo Sepolia.
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
CELO_MAINNET_RPC_URL=https://forno.celo.org

# Etherscan V2 unified key (also covers Celoscan) — https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# The payment token address is NOT read from here anymore — script/HelperConfig.s.sol picks it
# automatically based on block.chainid (COPm on mainnet, USDm stand-in on Celo Sepolia, a freshly
# deployed mock on Anvil). Edit HelperConfig.s.sol if those addresses ever change.

# Wallet of the transport company that receives collected fares (Celo Sepolia / Mainnet only —
# HelperConfig uses a well-known Anvil test account automatically for local runs).
TREASURY_ADDRESS=0xYOUR_TRANSPORT_COMPANY_WALLET
